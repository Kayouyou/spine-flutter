{
  "domain": "auth",
  "basePath": "/api/v1",
  "models": {
    "User": {
      "fields": {
        "id": "String",
        "email": "String",
        "name": "String?",
        "createdAt": "DateTime"
      },
      "hive": true,
      "hiveTypeId": 1
    },
    "AuthToken": {
      "fields": {
        "accessToken": "String",
        "refreshToken": "String",
        "expiresIn": "int"
      }
    }
  },
  "endpoints": [
    {
      "name": "login",
      "method": "POST",
      "path": "/auth/login",
      "response": "AuthToken",
      "body": {
        "email": "String",
        "password": "String"
      }
    },
    {
      "name": "getUser",
      "method": "GET",
      "path": "/auth/user",
      "response": "User",
      "params": {
        "id": "String"
      }
    }
  ]
}
