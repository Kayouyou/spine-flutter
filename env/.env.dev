ENV=dev
# API 基础地址 — 从此读取, 不再硬编码
API_BASE_URL=https://dev-api.example.com
# HTTP 主机 (不包含协议) — 续期/业务请求构造 URL 时使用
API_HOST=dev-api.example.com
# AccessKeyId 用于请求签名, 必须从 dart-define 注入, 不在源码出现
# (生产密钥应在 CI / 部署平台注入, 不提交)
API_ACCESS_KEY_ID=
# OSS 配置 — bucket + endpoint 由部署环境决定
OSS_BUCKET=ovsx-usr-dev
OSS_ENDPOINT=https://oss-cn-zhangjiakou.aliyuncs.com
OSS_ACCESS_KEY=
SENTRY_DSN=
APP_STORE_ID=
APP_VERSION=0.2.0
BUILD_NUMBER=1