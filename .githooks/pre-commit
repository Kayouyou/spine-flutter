#!/bin/bash
# pre-commit hook — 提交前自动运行静态分析和测试
# 任何一步失败会阻止提交

set -euo pipefail

echo "▸ 检查 ARB 翻译一致性..."
./scripts/check_l10n.sh

echo "▸ 运行 flutter analyze..."
# 本地只拦截 error，info/warning 交 CI 处理（避免 163 个预存 info 阻塞提交）
flutter analyze lib/ packages/ --no-fatal-infos --no-fatal-warnings

echo "▸ 运行变更相关包的测试..."
dart run melos test:affected

echo "✓ pre-commit 检查通过"
