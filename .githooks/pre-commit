#!/bin/bash
# pre-commit hook — 提交前自动运行静态分析和测试
# 任何一步失败会阻止提交

set -euo pipefail

echo "▸ 运行 flutter analyze..."
# --no-fatal-infos --no-fatal-warnings: info/warning 不阻止提交，仅 error 阻止
flutter analyze lib/ packages/ --no-fatal-infos --no-fatal-warnings

echo "▸ 运行单元测试和 Bloc 测试..."
flutter test test/unit/ test/bloc/

echo "✓ pre-commit 检查通过"
